{
  "name": "csc-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "db:sync": "prisma db push --skip-generate",
    "db:deploy": "prisma migrate deploy",
    "db:setup": "prisma db push --skip-generate && prisma db seed",
    "db:reset-dev": "prisma db push --force-reset --skip-generate && prisma db seed",
    "dev:setup": "prisma db push --skip-generate",
    "predev": "prisma db push --skip-generate",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:prod": "tsc",
    "start:prepare": "prisma generate && prisma migrate deploy",
    "start": "node dist/index.js",
    "start:prod": "npm run start:prepare && npm run build:prod && npm run start",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push --skip-generate",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "~5.8.2"
  }
}
