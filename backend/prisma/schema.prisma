generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  ADMIN_OBRA
  MEMBRO
}

enum InstallmentStatus {
  PENDING
  PAID
}

enum OrderStatus {
  PENDENTE
  EM_ANALISE
  AGUARDANDO_INFORMACAO
  CONCLUIDO
  CANCELADO
}

enum AttachmentKind {
  REQUEST
  COMPLETION
  ATTACHMENT
  PAYMENT_PROOF
  MESSAGE
  COST_DOCUMENT
  PROVISIONING_ATTACHMENT
  PROVISIONING_HISTORY_ATTACHMENT
  PROVISIONING_APPROVAL_ATTACHMENT
}

enum ProvisioningStatus {
  RASCUNHO
  PREVISTO
  EM_ANALISE
  APROVADO
  CANCELADO
  REALIZADO
}

model User {
  id                Int            @id @default(autoincrement())
  email             String         @unique @map("email")
  passwordHash      String         @map("senha_hash")
  name              String         @map("nome")
  role              UserRole       @map("perfil")
  managerId         Int?           @map("gestor_id")
  sectorId          Int?           @map("setor_id")
  canAccessProvisioning Boolean    @default(false) @map("pode_acessar_provisionamento")
  canCreateProvisioning Boolean    @default(false) @map("pode_criar_provisionamento")
  canApproveProvisioning Boolean   @default(false) @map("pode_aprovar_provisionamento")
  canViewProvisioningDashboard Boolean @default(false) @map("pode_dashboard_provisionamento")
  isActive          Boolean        @default(true) @map("ativo")
  createdAt         DateTime       @default(now()) @map("criado_em")
  updatedAt         DateTime       @updatedAt @map("atualizado_em")
  manager           User?          @relation("UserHierarchy", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates      User[]         @relation("UserHierarchy")
  sector            Sector?        @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  assignedProjects  UserProject[]
  ordersRequested   Order[]        @relation("RequesterOrders")
  ordersResponsible Order[]        @relation("ResponsibleOrders")
  orderMessages     OrderMessage[]
  provisioningCreated ProvisioningRecord[] @relation("ProvisioningCreatedBy")
  provisioningUpdated ProvisioningRecord[] @relation("ProvisioningUpdatedBy")
  provisioningApproved ProvisioningRecord[] @relation("ProvisioningApprovedBy")
  provisioningCancelled ProvisioningRecord[] @relation("ProvisioningCancelledBy")
  provisioningHistories ProvisioningHistory[]
  provisioningAttachments ProvisioningAttachment[] @relation("ProvisioningAttachmentUploadedBy")

  @@index([role, isActive])
  @@index([managerId])
  @@index([sectorId])

  @@map("usuarios")
}

model Sector {
  id            Int                 @id @default(autoincrement())
  name          String              @unique @map("nome")
  isActive      Boolean             @default(true) @map("ativo")
  createdAt     DateTime            @default(now()) @map("criado_em")
  updatedAt     DateTime            @updatedAt @map("atualizado_em")
  users         User[]
  statuses      SectorOrderStatus[]
  currentOrders Order[]             @relation("CurrentOrderSector")
  orderAccess   OrderSectorAccess[]

  @@index([name, isActive])

  @@map("setores")
}

model SectorOrderStatus {
  id        Int      @id @default(autoincrement())
  sectorId  Int      @map("setor_id")
  name      String   @map("nome")
  sortOrder Int      @default(0) @map("ordem")
  isActive  Boolean  @default(true) @map("ativo")
  createdAt DateTime @default(now()) @map("criado_em")
  updatedAt DateTime @updatedAt @map("atualizado_em")
  sector    Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@unique([sectorId, name])
  @@index([sectorId, sortOrder, isActive])

  @@map("setores_status_pedido")
}

model UserProject {
  userId     Int      @map("usuario_id")
  projectId  Int      @map("obra_id")
  createdAt  DateTime @default(now()) @map("criado_em")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
  @@index([projectId])

  @@map("usuarios_obras")
}

model Project {
  id            Int           @id @default(autoincrement())
  code          String        @unique @map("codigo")
  name          String     @map("nome")
  location      String     @map("localizacao")
  startDate     DateTime   @map("data_inicio")
  notes         String?    @db.Text @map("observacoes")
  lastOrderNumber Int       @default(0) @map("ultimo_numero_pedido")
  createdAt     DateTime   @default(now()) @map("criado_em")
  updatedAt     DateTime   @updatedAt @map("atualizado_em")
  budget        MacroItem[]
  costs         Cost[]
  installments  Installment[]
  orders        Order[]
  provisioningSequence ProvisioningSequence?
  provisioningRecords ProvisioningRecord[]
  assignedUsers UserProject[]

  @@index([name])
  @@index([code])
  @@index([startDate])

  @@map("obras")
}

model MacroItem {
  id            Int       @id @default(autoincrement())
  projectId     Int              @map("obra_id")
  description   String     @map("descricao")
  budgetedValue Decimal    @db.Decimal(15, 2) @map("valor_orcado")
  createdAt     DateTime   @default(now()) @map("criado_em")
  updatedAt     DateTime   @updatedAt @map("atualizado_em")
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costs         Cost[]
  installments  Installment[]
  orders        Order[]

  @@index([projectId])
  @@index([description])

  @@map("itens_macro")
}

model Cost {
    id            Int              @id @default(autoincrement())
    projectId     Int              @map("obra_id")
    macroItemId   Int              @map("item_macro_id")
    originOrderId Int?             @map("origem_pedido_id")
    originInstallmentId Int?       @map("origem_parcela_id")
    description   String     @map("descricao")
    itemDetail    String?          @db.Text @map("detalhe_item")
    unit          String           @map("unidade")
  quantity      Decimal          @db.Decimal(15, 3) @map("quantidade")
  unitValue     Decimal          @db.Decimal(15, 2) @map("valor_unitario")
  totalValue    Decimal          @db.Decimal(15, 2) @map("valor_total")
  occurredAt    DateTime         @map("data_ocorrencia")
  recordedAt    DateTime         @map("data_lancamento")
  createdAt     DateTime         @default(now()) @map("criado_em")
  updatedAt     DateTime         @updatedAt @map("atualizado_em")
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  macroItem     MacroItem        @relation(fields: [macroItemId], references: [id])
  attachments   CostAttachment[]

    @@index([projectId])
    @@index([macroItemId])
    @@index([originOrderId])
    @@index([originInstallmentId])
    @@index([occurredAt])

  @@map("custos")
}

model CostAttachment {
  id           Int            @id @default(autoincrement())
  costId       Int            @map("custo_id")
  kind         AttachmentKind @default(COST_DOCUMENT) @map("tipo")
  name         String         @map("nome")
  originalName String?        @map("nome_original")
  data         String?        @db.LongText @map("dados")
  storageProvider String?     @map("provedor_armazenamento")
  storageBucket String?       @map("bucket_armazenamento")
  storageKey   String?        @map("chave_armazenamento")
  mimeType     String         @map("tipo_mime")
  size         Int            @map("tamanho")
  uploadedAt   DateTime       @map("enviado_em")
  cost         Cost           @relation(fields: [costId], references: [id], onDelete: Cascade)

  @@index([costId])

  @@map("custos_anexos")
}

model Installment {
  id                Int                @id @default(autoincrement())
  projectId         Int                @map("obra_id")
  macroItemId       Int                @map("item_macro_id")
  provider          String             @map("fornecedor")
  description       String             @db.Text @map("descricao")
  totalValue        Decimal            @db.Decimal(15, 2) @map("valor_total")
  installmentNumber Int                @map("numero_parcela")
  totalInstallments Int                @map("total_parcelas")
  dueDate           DateTime           @map("data_vencimento")
  value             Decimal            @db.Decimal(15, 2) @map("valor")
  digitalLine       String?            @map("linha_digitavel")
  status            InstallmentStatus  @default(PENDING) @map("status")
  createdAt         DateTime           @default(now()) @map("criado_em")
  updatedAt         DateTime           @updatedAt @map("atualizado_em")
  project           Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  macroItem         MacroItem          @relation(fields: [macroItemId], references: [id])
  attachments       InstallmentAttachment[]

  @@index([projectId])
  @@index([macroItemId])
  @@index([dueDate])
  @@index([status])

  @@map("parcelas")
}

model InstallmentAttachment {
  id            Int            @id @default(autoincrement())
  installmentId Int            @map("parcela_id")
  kind          AttachmentKind @map("tipo")
  name          String     @map("nome")
  originalName  String?        @map("nome_original")
  data          String?        @db.LongText @map("dados")
  storageProvider String?      @map("provedor_armazenamento")
  storageBucket String?        @map("bucket_armazenamento")
  storageKey    String?        @map("chave_armazenamento")
  mimeType      String         @map("tipo_mime")
  size          Int            @map("tamanho")
  uploadedAt    DateTime       @map("enviado_em")
  installment   Installment    @relation(fields: [installmentId], references: [id], onDelete: Cascade)

  @@index([installmentId])

  @@map("parcelas_anexos")
}

model OrderType {
  id        Int       @id @default(autoincrement())
  name      String    @unique @map("nome")
  sortOrder Int       @default(0) @map("ordem")
  isActive  Boolean   @default(true) @map("ativo")
  createdAt DateTime  @default(now()) @map("criado_em")
  updatedAt DateTime  @updatedAt @map("atualizado_em")
  orders    Order[]

  @@index([sortOrder, isActive])

  @@map("tipos_pedido")
}

model Order {
  id                 Int           @id @default(autoincrement())
  projectId          Int           @map("obra_id")
  orderTypeId        Int           @map("tipo_pedido_id")
  macroItemId        Int?          @map("item_macro_id")
  currentSectorId    Int?          @map("setor_atual_id")
  requesterUserId    Int           @map("solicitante_usuario_id")
  assignedUserId     Int?          @map("responsavel_usuario_id")
  orderCode          String        @unique @map("codigo_pedido")
  externalCode       String?       @map("codigo_externo")
  title              String        @map("titulo")
  description        String        @db.Text @map("descricao")
  expectedDate       DateTime      @map("data_prevista")
  status             OrderStatus   @default(PENDENTE) @map("status")
  sectorStatus       String?       @map("status_setorial")
  completionNote     String?       @db.Text @map("observacao_conclusao")
  cancellationReason String?       @db.Text @map("motivo_cancelamento")
  requestedValue     Decimal?      @db.Decimal(15, 2) @map("valor_solicitado")
  createdAt          DateTime      @default(now()) @map("criado_em")
  updatedAt          DateTime      @updatedAt @map("atualizado_em")
  project            Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  orderType          OrderType     @relation(fields: [orderTypeId], references: [id])
  macroItem          MacroItem?    @relation(fields: [macroItemId], references: [id])
  currentSector      Sector?       @relation("CurrentOrderSector", fields: [currentSectorId], references: [id], onDelete: SetNull)
  requester          User          @relation("RequesterOrders", fields: [requesterUserId], references: [id])
  responsible        User?         @relation("ResponsibleOrders", fields: [assignedUserId], references: [id])
  attachments        OrderAttachment[]
  messages           OrderMessage[]
  sectorAccess       OrderSectorAccess[]

  @@index([projectId])
  @@index([orderCode])
  @@index([externalCode])
  @@index([orderTypeId])
  @@index([macroItemId])
  @@index([currentSectorId])
  @@index([requesterUserId])
  @@index([assignedUserId])
  @@index([status])
  @@index([expectedDate])

  @@map("pedidos")
}

model OrderSectorAccess {
  orderId     Int       @map("pedido_id")
  sectorId    Int       @map("setor_id")
  grantedAt   DateTime  @default(now()) @map("criado_em")
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sector      Sector    @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@id([orderId, sectorId])
  @@index([sectorId])

  @@map("pedidos_setores_acesso")
}

model OrderAttachment {
  id           Int            @id @default(autoincrement())
  orderId       Int            @map("pedido_id")
  kind          AttachmentKind @map("tipo")
  name          String     @map("nome")
  originalName  String?        @map("nome_original")
  data          String?        @db.LongText @map("dados")
  storageProvider String?      @map("provedor_armazenamento")
  storageBucket String?        @map("bucket_armazenamento")
  storageKey    String?        @map("chave_armazenamento")
  mimeType      String         @map("tipo_mime")
  size          Int            @map("tamanho")
  uploadedAt    DateTime       @map("enviado_em")
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])

  @@map("pedidos_anexos")
}

model OrderMessage {
  id          Int                    @id @default(autoincrement())
  orderId     Int                    @map("pedido_id")
  userId      Int?                   @map("usuario_id")
  body        String                 @db.LongText @map("conteudo")
  isSystem    Boolean                @default(false) @map("sistema")
  createdAt   DateTime               @default(now()) @map("criado_em")
  order       Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user        User?                  @relation(fields: [userId], references: [id])
  attachments OrderMessageAttachment[]

  @@index([orderId])
  @@index([userId])

  @@map("pedidos_mensagens")
}

model OrderMessageAttachment {
  id             Int            @id @default(autoincrement())
  orderMessageId Int            @map("mensagem_pedido_id")
  kind           AttachmentKind @default(MESSAGE) @map("tipo")
  name           String         @map("nome")
  originalName   String?        @map("nome_original")
  data           String?        @db.LongText @map("dados")
  storageProvider String?       @map("provedor_armazenamento")
  storageBucket String?         @map("bucket_armazenamento")
  storageKey     String?        @map("chave_armazenamento")
  mimeType       String         @map("tipo_mime")
  size           Int            @map("tamanho")
  uploadedAt     DateTime       @map("enviado_em")
  message        OrderMessage   @relation(fields: [orderMessageId], references: [id], onDelete: Cascade)

  @@index([orderMessageId])

  @@map("pedidos_mensagens_anexos")
}

model ProvisioningCategory {
  id          Int                 @id @default(autoincrement())
  name        String              @unique @map("nome")
  description String?             @db.Text @map("descricao")
  sortOrder   Int                 @default(0) @map("ordem")
  isActive    Boolean             @default(true) @map("ativo")
  createdAt   DateTime            @default(now()) @map("criado_em")
  updatedAt   DateTime            @updatedAt @map("atualizado_em")
  records     ProvisioningRecord[]

  @@index([sortOrder, isActive])
  @@map("provisionamento_categorias")
}

model ProvisioningSequence {
  projectId   Int      @id @map("obra_id")
  lastNumber  Int      @default(0) @map("ultimo_numero")
  createdAt   DateTime @default(now()) @map("criado_em")
  updatedAt   DateTime @updatedAt @map("atualizado_em")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("provisionamento_sequencias")
}

model ProvisioningRecord {
  id              Int                 @id @default(autoincrement())
  projectId       Int                 @map("obra_id")
  categoryId      Int                 @map("categoria_id")
  code            String              @unique @map("codigo")
  title           String              @map("titulo")
  description     String              @db.Text @map("descricao")
  supplier        String?             @map("fornecedor")
  dueDate         DateTime            @map("data_prevista")
  forecastValue   Decimal             @db.Decimal(15, 2) @map("valor_previsto")
  status          ProvisioningStatus  @default(PREVISTO) @map("status")
  comment         String?             @db.Text @map("comentario")
  createdByUserId Int                 @map("criado_por_usuario_id")
  updatedByUserId Int?                @map("atualizado_por_usuario_id")
  approvedByUserId Int?               @map("aprovado_por_usuario_id")
  approvedAt      DateTime?           @map("aprovado_em")
  cancelledByUserId Int?              @map("cancelado_por_usuario_id")
  cancelledAt     DateTime?           @map("cancelado_em")
  realizedAt      DateTime?           @map("realizado_em")
  createdAt       DateTime            @default(now()) @map("criado_em")
  updatedAt       DateTime            @updatedAt @map("atualizado_em")
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category        ProvisioningCategory @relation(fields: [categoryId], references: [id])
  createdBy       User                @relation("ProvisioningCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy       User?               @relation("ProvisioningUpdatedBy", fields: [updatedByUserId], references: [id])
  approvedBy      User?               @relation("ProvisioningApprovedBy", fields: [approvedByUserId], references: [id])
  cancelledBy     User?               @relation("ProvisioningCancelledBy", fields: [cancelledByUserId], references: [id])
  attachments     ProvisioningAttachment[]
  histories       ProvisioningHistory[]

  @@index([projectId, dueDate])
  @@index([categoryId, dueDate])
  @@index([status, dueDate])
  @@index([createdByUserId, createdAt])
  @@map("provisionamentos")
}

model ProvisioningAttachment {
  id             Int            @id @default(autoincrement())
  provisioningId Int            @map("provisionamento_id")
  historyId      Int?           @map("historico_id")
  kind           AttachmentKind @default(PROVISIONING_ATTACHMENT) @map("tipo")
  name           String         @map("nome")
  originalName   String?        @map("nome_original")
  data           String?        @db.LongText @map("dados")
  storageProvider String?       @map("provedor_armazenamento")
  storageBucket  String?        @map("bucket_armazenamento")
  storageKey     String?        @map("chave_armazenamento")
  mimeType       String         @map("tipo_mime")
  size           Int            @map("tamanho")
  uploadedByUserId Int          @map("usuario_id")
  uploadedAt     DateTime       @map("enviado_em")
  provisioning   ProvisioningRecord @relation(fields: [provisioningId], references: [id], onDelete: Cascade)
  history        ProvisioningHistory? @relation(fields: [historyId], references: [id], onDelete: SetNull)
  uploadedBy     User           @relation("ProvisioningAttachmentUploadedBy", fields: [uploadedByUserId], references: [id])

  @@index([provisioningId, uploadedAt])
  @@index([historyId])
  @@index([uploadedByUserId])
  @@map("provisionamentos_anexos")
}

model ProvisioningHistory {
  id             Int                 @id @default(autoincrement())
  provisioningId Int                 @map("provisionamento_id")
  userId         Int?                @map("usuario_id")
  action         String              @map("acao")
  description    String              @db.Text @map("descricao")
  statusFrom     ProvisioningStatus? @map("status_anterior")
  statusTo       ProvisioningStatus? @map("status_novo")
  createdAt      DateTime            @default(now()) @map("criado_em")
  provisioning   ProvisioningRecord  @relation(fields: [provisioningId], references: [id], onDelete: Cascade)
  user           User?               @relation(fields: [userId], references: [id])
  attachments    ProvisioningAttachment[]

  @@index([provisioningId, createdAt])
  @@index([userId])
  @@map("provisionamentos_historico")
}
